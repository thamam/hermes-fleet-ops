From 91b214e11b4f3ae922aaff11983e65194763a777 Mon Sep 17 00:00:00 2001
From: Tomer Hamam <tomer@neuronbox.ai>
Date: Mon, 15 Jun 2026 07:34:54 +0300
Subject: [PATCH] fix(gemini): route /openai-suffixed base_url through native
 client

# Status: requires-manual-rebase
# Reason: semantic conflict with upstream `is_native_gemini_base_url`
# behavior (upstream returns False for /openai; this carry returns True).
# Resolved manually on 2026-06-15 against upstream main HEAD fc2b8b3d.
# Each future rebase will re-conflict until upstream changes design or
# accepts this design via PR.

Background:
Crash on nano2 2026-06-07 22:36:22 IDT: an image-bearing Telegram
message routed through Gemini-2.5-flash failed with HTTP 400 from the
OpenAI-compat endpoint ("Invalid content part type: image_url").

Root cause: model.base_url was https://generativelanguage.googleapis.com/v1beta/openai
(AI Studio OpenAI-compat shim). Hermes routed it through the OpenAI
client because is_native_gemini_base_url returned False for /openai
suffixed URLs. The OpenAI-compat shim does not support image_url parts.

This patch makes is_native_gemini_base_url return True for /openai-suffixed
URLs so they route through GeminiNativeClient, which strips /openai
internally and translates image_url data URLs into Gemini-native inlineData.

Upstream chose a different design: keeps the function returning False for
/openai, and has downstream call sites strip /openai before invoking the
native endpoint. Both approaches solve the original crash; this carry
preserves the single-decision-point semantics fleet bots rely on.
---
 agent/gemini_native_adapter.py            | 24 ++++++-
 tests/agent/test_gemini_native_adapter.py | 88 +++++++++++++++++++++++
 2 files changed, 110 insertions(+), 2 deletions(-)

diff --git a/agent/gemini_native_adapter.py b/agent/gemini_native_adapter.py
index a79effe..82666f6 100644
--- a/agent/gemini_native_adapter.py
+++ b/agent/gemini_native_adapter.py
@@ -52,13 +52,33 @@ def bare_gemini_model_id(model: str) -> str:
 
 
 def is_native_gemini_base_url(base_url: str) -> bool:
-    """Return True when the endpoint speaks Gemini's native REST API."""
+    """Return True when ``provider=gemini`` requests should route through
+    :class:`GeminiNativeClient` rather than the stock OpenAI client.
+
+    Returns True for BOTH of these shapes:
+
+    * The bare native endpoint
+      (``https://generativelanguage.googleapis.com/v1beta``) — the canonical
+      native API URL.
+    * The OpenAI-compat shim suffix ``/openai`` on the same host
+      (``…/v1beta/openai``) — the shim is brittle (see module docstring) and
+      cannot carry ``image_url`` content parts: Gemini's OpenAI-compat
+      endpoint rejects them with HTTP 400 "Invalid content part type:
+      image_url". Routing through the native client instead is always safe:
+      :class:`GeminiNativeClient.__init__` strips a trailing ``/openai`` from
+      the stored base URL, and :func:`_extract_multimodal_parts` translates
+      OpenAI-style ``image_url`` data-URI parts into Gemini's native
+      ``inlineData`` shape transparently.
+
+    Returns False for non-Gemini hosts so the caller still falls through to
+    the OpenAI client (custom proxies, mocks, etc.).
+    """
     normalized = str(base_url or "").strip().rstrip("/").lower()
     if not normalized:
         return False
     if "generativelanguage.googleapis.com" not in normalized:
         return False
-    return not normalized.endswith("/openai")
+    return True
 
 
 def probe_gemini_tier(
diff --git a/tests/agent/test_gemini_native_adapter.py b/tests/agent/test_gemini_native_adapter.py
index aa9b2a3..ed59c1c 100644
--- a/tests/agent/test_gemini_native_adapter.py
+++ b/tests/agent/test_gemini_native_adapter.py
@@ -237,6 +237,94 @@ def test_native_client_strips_self_prefix_from_model_url(monkeypatch):
     assert recorded["url"] == "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent"
 
 
+def test_is_native_gemini_base_url_accepts_openai_compat_suffix():
+    """Both the bare native URL and the /openai-suffixed OpenAI-compat URL
+    must route through GeminiNativeClient (which strips /openai internally).
+
+    This guards against the 2026-06-07 nano2 crash where a Gemini-routed
+    image-bearing message hit the OpenAI-compat endpoint and was rejected
+    with HTTP 400 "Invalid content part type: image_url".
+    """
+    from agent.gemini_native_adapter import is_native_gemini_base_url
+
+    # Native canonical
+    assert is_native_gemini_base_url("https://generativelanguage.googleapis.com/v1beta") is True
+    # OpenAI-compat shim suffix — must also route to native
+    assert is_native_gemini_base_url("https://generativelanguage.googleapis.com/v1beta/openai") is True
+    # Trailing slash variants
+    assert is_native_gemini_base_url("https://generativelanguage.googleapis.com/v1beta/") is True
+    assert is_native_gemini_base_url("https://generativelanguage.googleapis.com/v1beta/openai/") is True
+    # Non-Gemini hosts still fall through to OpenAI client
+    assert is_native_gemini_base_url("https://api.openai.com/v1") is False
+    assert is_native_gemini_base_url("") is False
+    assert is_native_gemini_base_url(None) is False  # type: ignore[arg-type]
+
+
+def test_native_client_normalizes_openai_compat_suffix_and_routes_image_url(monkeypatch):
+    """When the user has model.base_url=https://…/v1beta/openai configured,
+    GeminiNativeClient still posts to the bare native endpoint AND translates
+    OpenAI-style image_url data-URL content parts into Gemini inlineData.
+    """
+    import base64
+    from agent.gemini_native_adapter import GeminiNativeClient
+
+    recorded = {}
+
+    class DummyHTTP:
+        def post(self, url, json=None, headers=None, timeout=None):
+            recorded["url"] = url
+            recorded["json"] = json
+            return DummyResponse(
+                payload={
+                    "candidates": [
+                        {"content": {"parts": [{"text": "saw the cat"}]}, "finishReason": "STOP"}
+                    ],
+                    "usageMetadata": {"promptTokenCount": 1, "candidatesTokenCount": 1, "totalTokenCount": 2},
+                }
+            )
+
+        def close(self):
+            return None
+
+    monkeypatch.setattr("agent.gemini_native_adapter.httpx.Client", lambda *a, **k: DummyHTTP())
+
+    client = GeminiNativeClient(
+        api_key="AIza-test",
+        # User-configured OpenAI-compat URL — should be transparently normalized.
+        base_url="https://generativelanguage.googleapis.com/v1beta/openai",
+    )
+    # 1×1 transparent PNG as a data URL
+    png_bytes = bytes.fromhex(
+        "89504e470d0a1a0a0000000d49484452000000010000000108060000001f15c489"
+        "0000000d49444154789c63000100000005000160ad7f7d0000000049454e44ae426082"
+    )
+    data_url = "data:image/png;base64," + base64.b64encode(png_bytes).decode("ascii")
+    client.chat.completions.create(
+        model="gemini-2.5-flash",
+        messages=[
+            {
+                "role": "user",
+                "content": [
+                    {"type": "text", "text": "what is this?"},
+                    {"type": "image_url", "image_url": {"url": data_url}},
+                ],
+            }
+        ],
+    )
+
+    # /openai suffix is stripped; URL targets the native generateContent endpoint
+    assert recorded["url"] == (
+        "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent"
+    )
+    # Request body carries Gemini-native inlineData, not OpenAI-style image_url
+    body = recorded["json"]
+    parts = body["contents"][0]["parts"]
+    assert any("inlineData" in p for p in parts), parts
+    inline = next(p["inlineData"] for p in parts if "inlineData" in p)
+    assert inline["mimeType"] == "image/png"
+    assert base64.b64decode(inline["data"]) == png_bytes
+
+
 def test_native_http_error_keeps_status_and_retry_after():
     from agent.gemini_native_adapter import gemini_http_error
 
